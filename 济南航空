                        <div class="detail-item"><strong>证件类型：</strong>${record.idType}</div>
                        <div class="detail-item"><strong>证件号码：</strong>${record.idNumber}</div>
                        <div class="detail-item"><strong>出行日期：</strong>${record.date}</div>
                        <div class="detail-item"><strong>支付方式：</strong>${record.payment}</div>
                        <div class="detail-item"><strong>所属账号：</strong>${record.user}</div>
                    </div>
                `;
                bookingRecordsContainer.appendChild(recordElement);
            });
        }

        // 初始化显示
        updateBookingRecords();

        // 默认显示第一个面板（机票预订）
        document.getElementById('ticket-panel').classList.add('active');
    </script>
</body>
</html>
